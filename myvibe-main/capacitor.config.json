{
  "appId": "com.myvibecommunity.app",
  "appName": "MyVibe",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "App": {
      "deepLinks": [
        {
          "scheme": "https",
          "host": "myvibeapp.co",
          "paths": [
            "/:username/:slug",
            "/:username"
          ]
        }
      ]
    },
    "FirebaseMessaging": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    },
    "GoogleAuth": {
      "scopes": [
        "profile",
        "email"
      ],
      "serverClientId": "46760281130-718s2v8sbmtiu3h1ak5c2shchucfak8k.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    },
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#000",
      "splashFullScreen": true,
      "splashImmersive": true
    }
  },
  "icon": "assets/icon.png",
  "splash": "assets/splash.png",
  "androidClientId": "46738324149-sh3r3ko6d7rqicr5uvjnmt69f32tq8lv.apps.googleusercontent.com",
  "iosClientId": "46738324149-jgo4297c9p82210kjtfht3t811toluao.apps.googleusercontent.com"
}